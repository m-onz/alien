#N canvas 100 100 850 600 12;
#X text 20 10 [alien_router] - Route messages by first symbol;
#X text 20 30 Like [route] but outputs entire remaining message \, not just first element.;
#X text 20 60 ──────────────────────────────────────────────────────────;
#X text 20 80 CREATION;
#X text 30 100 [alien_router kick snare hat] - creates 4 outlets;
#X text 30 120 Outlets: kick \, snare \, hat \, unmatched;
#X text 20 150 BEHAVIOR;
#X text 30 170 Input: "kick (seq 1 2 3)" -> outlet 1 outputs "(seq 1 2 3)";
#X text 30 190 Input: "snare (euclid 3 8)" -> outlet 2 outputs "(euclid 3 8)";
#X text 30 210 Input: "crash (rep 1 4)" -> last outlet (unmatched);
#X text 20 240 ──────────────────────────────────────────────────────────;
#X text 20 260 EXAMPLE - click messages to route;
#X obj 200 450 alien_router kick snare hihat;
#X obj 200 490 print kick;
#X obj 300 490 print snare;
#X obj 400 490 print hihat;
#X obj 520 490 print unmatched;
#X msg 30 290 kick (seq 1 2 3 4);
#X msg 30 315 snare (euclid 3 8);
#X msg 30 340 hihat (seq 1 - 1 -);
#X msg 30 365 crash (rep 1 4);
#X msg 30 390 tom (choose 60 64 67);
#X text 500 80 USE CASE;
#X text 510 100 Multi-voice drum machine:;
#X text 510 120 Send "kick (pattern)" \, "snare (pattern)" etc;
#X text 510 140 Each voice gets routed to its own [alien];
#X text 510 180 Works with any symbol prefix \,;
#X text 510 200 not just drum names;
#X text 20 530 ──────────────────────────────────────────────────────────;
#X text 20 550 See also: [route] (built-in) - outputs only first element after match;
#X text 650 550 alien_router 0.2.1;
#X connect 17 0 12 0;
#X connect 18 0 12 0;
#X connect 19 0 12 0;
#X connect 20 0 12 0;
#X connect 21 0 12 0;
#X connect 12 0 13 0;
#X connect 12 1 14 0;
#X connect 12 2 15 0;
#X connect 12 3 16 0;
