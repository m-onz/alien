#N canvas 100 100 800 550 12;
#X text 20 10 [alien_cluster] - Diatonic cluster chord generator;
#X text 20 30 Generates cluster chords with compatible bass notes. Modulates harmonically.;
#X text 20 60 ──────────────────────────────────────────────────────────;
#X text 20 80 CREATION;
#X text 30 100 [alien_cluster] - root at MIDI 60;
#X text 30 120 [alien_cluster 48] - root at MIDI 48;
#X text 20 150 INLETS;
#X text 30 170 bang - generate new cluster chord;
#X text 30 190 float - set root and generate;
#X text 20 220 OUTLETS;
#X text 30 240 Left: cluster chord (4 MIDI notes);
#X text 30 260 Right: compatible bass notes (root \, fifth \, fourth);
#X text 20 290 ──────────────────────────────────────────────────────────;
#X text 20 310 EXAMPLE - click bang to generate;
#X obj 200 400 alien_cluster 48;
#X obj 91 340 bng 25 250 50 0 empty empty empty 0 -10 0 12 #fcfcfc #000000 #000000;
#X floatatom 150 340 5 0 0 0 - - - 0;
#X obj 200 430 print chord;
#X obj 320 430 print bass;
#X listbox 200 460 30 0 0 0 - - - 0;
#X listbox 320 460 30 0 0 0 - - - 0;
#X text 500 80 BEHAVIOR;
#X text 510 100 Each bang generates a new chord;
#X text 510 120 Chord modulates harmonically from previous;
#X text 510 140 (fifths \, fourths \, relative minor/major);
#X text 510 180 Cluster = 4 adjacent scale degrees;
#X text 510 200 Bass = root \, fifth \, fourth of new key;
#X text 500 240 USE CASE;
#X text 510 260 Jazz voicings \, ambient pads \,;
#X text 510 280 generative harmony;
#X text 20 500 ──────────────────────────────────────────────────────────;
#X text 600 500 alien_cluster 0.2.1;
#X connect 15 0 14 0;
#X connect 16 0 14 0;
#X connect 14 0 17 0;
#X connect 14 0 19 0;
#X connect 14 1 18 0;
#X connect 14 1 20 0;
