#N canvas 100 100 750 500 12;
#X text 20 10 [alien_buffer] - Pattern buffer;
#X text 20 30 Stores a pattern and outputs it on demand.;
#X text 20 60 ──────────────────────────────────────────────────────────;
#X text 20 80 INLETS;
#X text 30 100 Left: pattern list to store;
#X text 30 120 Right: bang to trigger output;
#X text 20 150 OUTLETS;
#X text 30 170 Stored pattern (on trigger);
#X text 20 200 ──────────────────────────────────────────────────────────;
#X text 20 220 EXAMPLE;
#X obj 200 350 alien_buffer;
#X obj 200 380 print output;
#X listbox 320 380 30 0 0 0 - - - 0;
#X msg 30 250 60 64 67 72;
#X msg 30 275 1 - 1 - 1 - 1 -;
#X msg 30 300 48 52 55 60 64 67;
#X obj 350 320 bng 25 250 50 0 empty empty trigger 0 -10 0 12 #fcfcfc #000000 #000000;
#X text 30 325 <- click to store;
#X text 420 320 <- click to output;
#X text 450 80 USE CASE;
#X text 460 100 Store a pattern \, trigger it later;
#X text 460 120 Useful for:;
#X text 470 140 - Preset recall;
#X text 470 160 - Pattern switching;
#X text 470 180 - Delayed pattern changes;
#X text 20 420 ──────────────────────────────────────────────────────────;
#X text 550 420 alien_buffer 0.2.1;
#X connect 13 0 10 0;
#X connect 14 0 10 0;
#X connect 15 0 10 0;
#X connect 16 0 10 1;
#X connect 10 0 11 0;
#X connect 10 0 12 0;
