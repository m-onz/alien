#N canvas 100 100 900 650 12;
#X text 20 10 [alien_groove] - Stochastic pattern filter;
#X text 20 30 Applies probabilistic masking to patterns. Creates groove and humanization.;
#X text 20 60 ──────────────────────────────────────────────────────────;
#X text 20 80 INLETS;
#X text 30 100 Left: pattern list (from [alien] or other source);
#X text 30 120 Right: template pattern (defines backbone rhythm);
#X text 20 150 BEHAVIOR;
#X text 30 170 With template: notes on template positions always pass through;
#X text 30 190 notes OFF template are dropped with probability = strictness;
#X text 30 210 Without template: ALL notes dropped with probability = strictness;
#X text 20 240 ──────────────────────────────────────────────────────────;
#X text 20 260 MESSAGES - click to send;
#X obj 200 520 alien_groove;
#X obj 200 550 print output;
#X listbox 320 550 40 0 0 0 - - - 0;
#X msg 30 280 strictness 0;
#X msg 130 280 strictness 30;
#X msg 240 280 strictness 70;
#X msg 350 280 strictness 100;
#X text 30 305 <- 0=all pass \, 100=all drop (except template hits);
#X msg 30 330 phase 0;
#X msg 100 330 phase 2;
#X msg 170 330 phase 4;
#X text 240 330 <- rotate template;
#X text 500 80 EXAMPLE: Groove template;
#X text 510 100 Template: (euclid 4 16) = kick pattern;
#X text 510 120 Input: full 16-note melody;
#X text 510 140 Result: melody on kicks always plays \,;
#X text 510 160 other notes randomly dropped;
#X text 500 200 TYPICAL SETTINGS;
#X text 510 220 strictness 20-40: subtle humanization;
#X text 510 240 strictness 50-70: noticeable thinning;
#X text 510 260 strictness 80-100: sparse \, ambient;
#X text 20 360 ──────────────────────────────────────────────────────────;
#X text 20 380 TEMPLATE INPUT (right inlet);
#X msg 30 400 1 - - - 1 - - - 1 - - - 1 - - -;
#X msg 30 425 1 - - 1 - - 1 -;
#X msg 30 450 - 1 - 1;
#X text 280 400 <- 4-on-floor;
#X text 280 425 <- tresillo;
#X text 280 450 <- offbeat;
#X text 20 480 TEST PATTERN (left inlet);
#X msg 30 500 60 61 62 63 64 65 66 67 68 69 70 71 72 73 74 75;
#X text 20 580 ──────────────────────────────────────────────────────────;
#X text 20 600 WORKFLOW: [alien] -> [alien_scale] -> [alien_groove] -> [sequencer];
#X text 700 600 alien_groove 0.2.1;
#X connect 15 0 12 0;
#X connect 16 0 12 0;
#X connect 17 0 12 0;
#X connect 18 0 12 0;
#X connect 20 0 12 0;
#X connect 21 0 12 0;
#X connect 22 0 12 0;
#X connect 35 0 12 1;
#X connect 36 0 12 1;
#X connect 37 0 12 1;
#X connect 42 0 12 0;
#X connect 12 0 13 0;
#X connect 12 0 14 0;
