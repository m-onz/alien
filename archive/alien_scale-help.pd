#N canvas 100 100 950 750 12;
#X text 20 10 [alien_scale] - Scale/mode quantizer with harmonic field control;
#X text 20 30 Maps scale degrees or MIDI notes to pitches in current scale.;
#X text 20 60 ──────────────────────────────────────────────────────────;
#X text 20 80 CREATION ARGUMENTS;
#X text 30 100 [alien_scale] - C major \, degree mode;
#X text 30 120 [alien_scale 60] - root at MIDI 60 \, major;
#X text 30 140 [alien_scale 60 minor] - C minor;
#X text 30 160 [alien_scale 48 dorian] - C dorian \, octave lower;
#X text 30 180 [alien_scale 60 minor quantize] - quantize mode;
#X text 20 210 ──────────────────────────────────────────────────────────;
#X text 20 230 MODES;
#X text 30 250 degree (default): input = scale degree index (0=root \, 1=2nd \, etc);
#X text 30 270 quantize: input = MIDI note \, snapped to nearest scale tone;
#X text 20 300 ──────────────────────────────────────────────────────────;
#X text 20 320 MESSAGES - click to send;
#X text 500 80 AVAILABLE SCALES;
#X text 510 100 major/ionian \, dorian \, phrygian \, lydian;
#X text 510 120 mixolydian \, aeolian/minor \, locrian;
#X text 510 140 pentatonic/pent \, minpent \, blues;
#X text 510 160 chromatic \, wholetone \, diminished \, augmented;
#X text 510 180 harmonic \, melodic;
#X text 510 200 hirajoshi \, insen \, iwato \, hungarian \, romanian;
#X obj 200 620 alien_scale 60 minor;
#X obj 200 650 print pitch;
#X floatatom 200 590 5 0 0 0 - - - 0;
#X msg 30 340 root 48;
#X msg 100 340 root 60;
#X msg 170 340 root 72;
#X text 240 340 <- set root note;
#X msg 30 370 scale minor;
#X msg 120 370 scale dorian;
#X msg 220 370 scale pentatonic;
#X msg 330 370 scale blues;
#X text 30 395 <- set scale by name;
#X msg 30 420 scale 0 2 4 5 7 9 11;
#X msg 200 420 scale 0 3 5 6 7 10;
#X text 370 420 <- custom intervals;
#X msg 30 450 mode degree;
#X msg 140 450 mode quantize;
#X text 270 450 <- set input mode;
#X msg 30 480 degrees 0 2 4;
#X msg 150 480 degrees 0 2 4 6;
#X msg 290 480 degrees off;
#X text 380 480 <- harmonic field filter;
#X msg 30 510 range 48 72;
#X msg 150 510 range 36 84;
#X text 270 510 <- output MIDI range;
#X msg 30 540 ref 60;
#X msg 100 540 intervals 0 4 7;
#X msg 230 540 intervals off;
#X text 340 540 <- interval filter;
#X text 500 320 EXAMPLE: degree mode;
#X text 510 340 Input 0 -> root (60);
#X text 510 360 Input 2 -> third (64);
#X text 510 380 Input 7 -> root+octave (72);
#X text 500 410 EXAMPLE: harmonic field;
#X text 510 430 degrees 0 2 4 = only triad tones;
#X text 510 450 Even if pattern has all degrees \,;
#X text 510 470 only I \, III \, V will sound;
#X text 20 680 ──────────────────────────────────────────────────────────;
#X text 20 700 WORKFLOW: [alien] -> [alien_scale 60 minor] -> [else/sequencer];
#X text 700 700 alien_scale 0.2.1;
#X connect 24 0 22 0;
